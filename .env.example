# =============================================================================
# Botero Trade Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env or .env.local — they contain secrets.
# =============================================================================

# ─── Database (Neon / Vercel Postgres) ───────────────────────────────────────
# Recommended for most uses (pooled via pgbouncer)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# Individual connection parameters
PGHOST=your-db-host
PGHOST_UNPOOLED=your-db-host-unpooled
PGUSER=your-db-user
PGDATABASE=your-db-name
PGPASSWORD=your-db-password

# Vercel Postgres template variables
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_USER=your-db-user
POSTGRES_HOST=your-db-host
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=your-db-name
POSTGRES_URL_NO_SSL=postgresql://user:password@host/dbname
POSTGRES_PRISMA_URL=postgresql://user:password@host/dbname?connect_timeout=15&sslmode=require

# ─── Brevo Email API ────────────────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_EMAILS_ACTIVE=true
BREVO_SENDER_EMAIL=info@yourdomain.com
BREVO_SENDER_NAME="Your Sender Name"

# ─── Payload CMS ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PROJECT_ID=botero-trade
BLOB_READ_WRITE_TOKEN=your-blob-token
PAYLOAD_SECRET=your-payload-secret
PREVIEW_SECRET=your-preview-secret
CRON_SECRET=your-cron-secret

# ─── Vercel (auto-set on Vercel, optional locally) ──────────────────────────
# VERCEL_PROJECT_PRODUCTION_URL=your-production-domain.vercel.app
# VERCEL_URL=your-vercel-url.vercel.app

# ─── Python Trading Engine ──────────────────────────────────────────────────
TRADING_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Alpaca Broker ──────────────────────────────────────────────────────────
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Interactive Brokers (TWS / IB Gateway) ─────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497
IB_ACCOUNT_ID=
IB_CLIENT_ID=1

# ─── GuruFocus Data API (MCP) ───────────────────────────────────────────────
GURUFOCUS_API_TOKEN=your-gurufocus-api-token

# ─── Cloudflare Tunnel (Docker only) ────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
