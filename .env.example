# ─── Database (external — not managed by Docker) ─────────────────────────────
# PostgreSQL must be hosted externally. Options:
#   - Vercel Postgres:  https://vercel.com/storage/postgres
#   - Neon:             https://neon.tech
#   - Supabase:         https://supabase.com
#   - Local instance:   postgres://postgres:<password>@127.0.0.1:5432/botero_trade
POSTGRES_URL=postgres://postgres:<password>@<host>:5432/<database>

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Project identifier for organizing blob storage
PROJECT_ID=your-project-name

# Vercel Blob storage token (get from Vercel dashboard)
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# ─── Python Trading Engine ────────────────────────────────────────────────────

# URL where the FastAPI trading engine is reachable from the Next.js app
# In Docker: http://api:8000  |  Local dev: http://localhost:8000
TRADING_API_URL=http://localhost:8000

# URL of the frontend (used by FastAPI for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Interactive Brokers ──────────────────────────────────────────────────────
# Requires TWS or IB Gateway running locally (not inside Docker)
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ─── Alpaca ───────────────────────────────────────────────────────────────────
# Get keys from https://alpaca.markets — defaults to paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
