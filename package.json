{
  "name": "botero-trade",
  "version": "0.1.0",
  "description": "Botero Trade — algorithmic trading engine with Next.js + PayloadCMS frontend and Python FastAPI trading backend",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "dev:webpack": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate": "pnpm generate:types && pnpm generate:importmap",
    "dev:api": "cd backend && .venv/bin/uvicorn api.main:app --reload --port 8000",
    "dev:all": "concurrently --names \"web,api\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"pnpm dev\" \"pnpm dev:api\"",
    "docker:up": "docker compose up",
    "docker:build": "docker compose build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@payloadcms/admin-bar": "^3.75.0",
    "@payloadcms/db-vercel-postgres": "^3.75.0",
    "@payloadcms/live-preview-react": "^3.75.0",
    "@payloadcms/next": "^3.75.0",
    "@payloadcms/payload-cloud": "^3.75.0",
    "@payloadcms/plugin-form-builder": "^3.75.0",
    "@payloadcms/plugin-nested-docs": "^3.75.0",
    "@payloadcms/plugin-redirects": "^3.75.0",
    "@payloadcms/plugin-search": "^3.75.0",
    "@payloadcms/plugin-seo": "^3.75.0",
    "@payloadcms/richtext-lexical": "^3.75.0",
    "@payloadcms/storage-vercel-blob": "^3.75.0",
    "@payloadcms/ui": "^3.75.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "framer-motion": "^12.37.0",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "^0.378.0",
    "next": "16.1.7",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "payload": "^3.75.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.45.4",
    "sharp": "0.32.6",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/typography": "^0.5.13",
    "@types/escape-html": "^1.0.2",
    "@types/node": "^22.5.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.1.7",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
